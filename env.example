# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin Authentication
ADMIN_USER=admin
ADMIN_PASS=admin
# IMPORTANTE: Cambia esta contraseña en producción por una segura

# Session Security
# Genera una clave secreta aleatoria (mínimo 32 caracteres)
# Puedes generarla con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=default-secret-change-in-production

# Optional: used by `npm run seed` (supabase db reset --db-url)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Email Configuration - Gmail SMTP
# Configura una cuenta de Gmail y genera una App Password:
# 1. Ve a tu cuenta de Google: https://myaccount.google.com/
# 2. Seguridad > Verificación en 2 pasos (debe estar activada)
# 3. Contraseñas de aplicaciones > Generar nueva contraseña
# 4. Copia la contraseña generada (16 caracteres)
GMAIL_USER=tu_email@gmail.com
GMAIL_APP_PASSWORD=tu_app_password_de_16_caracteres
GMAIL_FROM_NAME=Nombre que vera el destinatario
